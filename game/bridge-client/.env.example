# Copy to .env to override the default server URLs.
# Defaults (no .env needed) point at local dev servers.
VITE_BACKEND_URL=http://localhost:4000
VITE_GAME_URL=http://localhost:5000

# ---- Analytics (optional) ----
# Off by default (VITE_ANALYTICS=none) → events buffer locally in
# window.__gpAnalytics for dev inspection, nothing is sent anywhere.
# To send to a provider, set ONE of the following at build time:
#
# PostHog:
#   VITE_ANALYTICS=posthog
#   VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxx
#   VITE_POSTHOG_HOST=https://us.i.posthog.com   # or your self-hosted host
#   (also run: npm i posthog-js  — it's only needed when you opt in)
#
# Google Analytics 4:
#   VITE_ANALYTICS=ga4
#   VITE_GA4_ID=G-XXXXXXXXXX
VITE_ANALYTICS=none

# ---- CrazyGames build (optional) ----
# Only set this for the build you UPLOAD TO CRAZYGAMES. It loads their SDK,
# reports loading/gameplay/rooms, and shows midgame ads between races.
# The normal (Render) build must NOT set this — SDK calls are disabled off
# CrazyGames domains and the wrapper stays a silent no-op.
# Build with:  ./build-crazygames.sh   (outputs dist-cg/ + a ready upload zip)
# VITE_CRAZYGAMES=1
