# Copy to .env and fill in. Dev defaults work without any of these.
PORT=4000
DATA_STORE=memory

# Session signing — CHANGE in production.
JWT_SECRET=dev-only-change-me

# Admin gate — separate from player auth. CHANGE in production.
ADMIN_KEY=dev-admin-key

# Google OAuth — substitute real keys before testing real sign-in.
GOOGLE_CLIENT_ID=PLACEHOLDER_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=PLACEHOLDER_GOOGLE_CLIENT_SECRET
